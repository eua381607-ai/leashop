# Copy this file to `.env` and fill in real values. Never commit `.env` itself.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave unset locally to use SQLite automatically.
# On Railway, attach a PostgreSQL plugin: it injects DATABASE_URL for you.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Stripe (get test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# ── Emails ─────────────────────────────────────────────────────────────
# Par défaut, les emails s'affichent dans la console (pour le développement local).
# Pour un envoi réel (production), choisissez "smtp" ou "resend".

# Option 1: Utilisation d'un serveur SMTP classique (ex: Gmail, Brevo, Mailgun)
# EMAIL_PROVIDER=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=votre-email@gmail.com
# EMAIL_HOST_PASSWORD=votre-mot-de-passe-d-application
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False

# Option 2: Utilisation de Resend (alternative moderne)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_123456789

# L'adresse email expéditrice par défaut
# DEFAULT_FROM_EMAIL=contact@votre-domaine.com

STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd
STRIPE_PAYMENT_METHOD_TYPES=card
# Leave blank until you have a real provider endpoint.
MOBILE_MONEY_API_URL=
MOBILE_MONEY_API_KEY=
MOBILE_MONEY_WEBHOOK_SECRET=

# To enable mobile money support in Stripe Checkout, set this to:
# STRIPE_PAYMENT_METHOD_TYPES=card,mobile_money

# Used to build absolute Stripe redirect URLs
SITE_BASE_URL=http://127.0.0.1:8000
